{
  "name": "@worker-app/notification-service",
  "version": "1.0.0",
  "description": "Notification service — push notifications + real-time chat via Socket.io",
  "main": "dist/app.js",
  "scripts": {
    "dev":          "ts-node-dev --respawn --transpile-only src/app.ts",
    "build":        "tsc",
    "start":        "node dist/app.js",
    "lint":         "eslint src/**/*.ts",
    "lint:fix":     "eslint src/**/*.ts --fix",
    "format":       "prettier --write src/**/*.ts",
    "format:check": "prettier --check src/**/*.ts"
  },
  "dependencies": {
    "cors":               "^2.8.5",
    "dotenv":             "^16.3.1",
    "express":            "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "firebase-admin":     "^12.0.0",
    "helmet":             "^7.1.0",
    "socket.io":          "^4.6.1",
    "winston":            "^3.11.0"
  },
  "devDependencies": {
    "@types/cors":                      "^2.8.17",
    "@types/express":                   "^4.17.21",
    "@types/node":                      "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser":        "^6.13.0",
    "eslint":                           "^8.54.0",
    "eslint-config-prettier":           "^9.0.0",
    "eslint-plugin-prettier":           "^5.0.1",
    "prettier":                         "^3.1.0",
    "ts-node-dev":                      "^2.0.0",
    "typescript":                       "^5.3.2"
  }
}
