# App
PORT=
NODE_ENV=

# Inter-service
INTERNAL_SECRET=

# Firebase FCM — for push notifications
# Get this from Firebase Console → Project Settings → Service Accounts → Generate new private key
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Socket.io CORS
ALLOWED_ORIGINS=

# Rate limiting
RATE_LIMIT_WINDOW_MS=
RATE_LIMIT_MAX=
