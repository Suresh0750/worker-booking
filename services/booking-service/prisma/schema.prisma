generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Booking {
  id          String        @id @default(uuid())
  userId      String        @map("user_id")
  workerId    String        @map("worker_id")
  categoryId  String        @map("category_id")

  // Denormalized — stored at booking time so we don't need to call other services later
  userName    String?       @map("user_name")
  workerName  String?       @map("worker_name")
  categoryName String?      @map("category_name")

  description  String
  address      String        // Full address string where work is needed
  city         String
  lat          Float?
  lng          Float?

  status       BookingStatus @default(PENDING)
  priceAgreed  Float?        @map("price_agreed")
  scheduledAt  DateTime?     @map("scheduled_at")

  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt      @map("updated_at")

  messages     Message[]
  statusLogs   BookingStatusLog[]

  @@map("bookings")
}

// Every status change is logged — full audit trail
model BookingStatusLog {
  id        String        @id @default(uuid())
  bookingId String        @map("booking_id")
  fromStatus BookingStatus? @map("from_status")
  toStatus  BookingStatus @map("to_status")
  changedBy String        @map("changed_by")  // userId who made the change
  note      String?
  createdAt DateTime      @default(now()) @map("created_at")

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@map("booking_status_logs")
}

model Message {
  id         String   @id @default(uuid())
  bookingId  String   @map("booking_id")
  senderId   String   @map("sender_id")
  senderRole String   @map("sender_role")  // USER or WORKER
  content    String
  sentAt     DateTime @default(now()) @map("sent_at")

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@map("messages")
}

enum BookingStatus {
  PENDING
  ACCEPTED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}
