generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Worker {
  id              String       @id  // Same UUID as auth_db users.id
  userId          String?       @unique
  email           String       @unique
  name            String?
  phone           String?
  avatar          String?
  bio             String?
  experienceYears Int          @default(0) @map("experience_years")
  avgRating       Float        @default(0) @map("avg_rating")
  totalReviews    Int          @default(0) @map("total_reviews")
  availability    Availability @default(AVAILABLE)
  isVerified      Boolean      @default(false) @map("is_verified")
  isActive        Boolean      @default(true)  @map("is_active")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt      @map("updated_at")

  addresses        WorkerAddress[]
  workerCategories WorkerCategory[]
  portfolios       Portfolio[]
  rate             Int          @default(0)
  rateType         RateType     @default(RateType)
  slotType         SlotType     @default(SlotType)
  @@map("workers")
}

model Category {
  id       String @id @default(uuid())
  name     String @unique         // carpenter, electrician, plumber etc.
  slug     String @unique         // carpenter, electrician, plumber etc.
  iconUrl  String? @map("icon_url")

  workerCategories WorkerCategory[]

  @@map("categories")
}

model WorkerCategory {
  workerId   String @map("worker_id")
  categoryId String @map("category_id")

  worker   Worker   @relation(fields: [workerId],   references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([workerId, categoryId])
  @@map("worker_categories")
}

model WorkerAddress {
  id        String  @id @default(uuid())
  workerId  String  @map("worker_id")
  line1     String
  line2     String?
  city      String
  state     String
  pincode   String
  lat       Float                         // Required for geo search
  lng       Float
  isPrimary Boolean @default(false) @map("is_primary")

  worker Worker @relation(fields: [workerId], references: [id], onDelete: Cascade)

  @@map("worker_addresses")
}

model Portfolio {
  id         String    @id @default(uuid())
  workerId   String    @map("worker_id")
  mediaUrl   String    @map("media_url")   // S3 / Cloudinary CDN URL
  mediaType  MediaType @map("media_type")
  caption    String?
  uploadedAt DateTime  @default(now()) @map("uploaded_at")

  worker Worker @relation(fields: [workerId], references: [id], onDelete: Cascade)

  @@map("portfolios")
}

enum Availability {
  AVAILABLE
  BUSY
  UNAVAILABLE
}

enum MediaType {
  IMAGE
  VIDEO
}


enum RateType {
  DAILY
  HOURLY
}

enum SlotType {
  HYBRID
  REQUEST_BASED
  SLOT_BASED
}